# Demo publica / desarrollo visual sin backend.
# local no significa localhost: significa finalizacion sin backend.
VITE_TERRITORIO_DATA_SOURCE=mock
VITE_RELEVAMIENTO_FINALIZATION_MODE=local
VITE_API_BASE_URL=
VITE_CUADRANTE_IMAGE_BASE_URL=

# Backend de prueba.
# Copiar estos valores en frontend/.env local solo cuando corresponda probar contra backend real.
# Puede fallar desde navegador por CORS si backend/infra no permite el origen local.
# VITE_TERRITORIO_DATA_SOURCE=api
# VITE_RELEVAMIENTO_FINALIZATION_MODE=backend
# VITE_API_BASE_URL=http://10.100.66.32:8000/api/v1
# VITE_CUADRANTE_IMAGE_BASE_URL=http://10.100.66.32:8000/zona1

# Servidor final interno.
# Pendiente de confirmar por infraestructura:
# - si frontend y API comparten origen;
# - si la API queda bajo /sistema-censo/api/v1 o /api/v1;
# - si se usara HTTP o HTTPS;
# - si habra proxy Nginx/Apache.
# VITE_TERRITORIO_DATA_SOURCE=api
# VITE_RELEVAMIENTO_FINALIZATION_MODE=backend
# VITE_API_BASE_URL=/api/v1
# VITE_CUADRANTE_IMAGE_BASE_URL=/zona1
